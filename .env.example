# SentiLens Environment Variables
# Copy this file to .env.local and fill in the values.

# Google AI Configuration
# IMPORTANT: For PRODUCTION, ensure your API key is restricted to your 
# domain/application in the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_API_KEY=

# Google Cloud / Firebase (Optional for prototyping, required for production)
# GOOGLE_APPLICATION_CREDENTIALS=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Gemini Models
GEMINI_MODEL_ID=gemini-3-flash-preview

# Firestore collections (defaults to SentiLensSessions if not set)
SESSIONS_COLLECTION=SentiLensSessions
